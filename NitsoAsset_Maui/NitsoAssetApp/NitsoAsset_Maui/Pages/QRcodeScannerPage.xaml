<?xml version="1.0" encoding="UTF-8" ?>
<pages:CustomPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                  xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                  xmlns:pages="clr-namespace:NitsoAsset_Maui.Pages.Base;assembly=NitsoAsset_Maui"
                  xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
                  xmlns:controls="clr-namespace:NitsoAsset_Maui.Assets.Controls"
                  xmlns:zxing="clr-namespace:ZXing.Net.Maui.Controls;assembly=ZXing.Net.MAUI.Controls"
                  ios:Page.UseSafeArea="true"
                  NavigationPage.HasNavigationBar="True"
                  Title="sfasd"
                  x:Class="NitsoAsset_Maui.Pages.QRcodeScannerPage">
    <NavigationPage.TitleView>
        <StackLayout HorizontalOptions="FillAndExpand" VerticalOptions="CenterAndExpand" Background="Transparent">
            <ImageButton Source="no_flash" HeightRequest="25" WidthRequest="25" HorizontalOptions="EndAndExpand"
                         Margin="0,0,10,0" VerticalOptions="CenterAndExpand" BackgroundColor="Transparent" Command="{Binding FlashCommand}">
                <ImageButton.Triggers>
                    <DataTrigger TargetType="ImageButton" Binding="{Binding IsTorch}" Value="false">
                        <Setter Property="Source" Value="flash_on"/>
                    </DataTrigger>
                </ImageButton.Triggers>
            </ImageButton>
        </StackLayout>
    </NavigationPage.TitleView>
    <pages:CustomPage.Content>
        <!--<AbsoluteLayout>
            <dynamsoft:DCVCameraView OverlayVisible="True"
                                     x:Name="scanner"
							         AbsoluteLayout.LayoutBounds="0,0,1,1"
                                     AbsoluteLayout.LayoutFlags="All">
                <dynamsoft:DCVCameraView.TorchButton>
                    <dynamsoft:TorchButton Visible="True">
                    </dynamsoft:TorchButton>
                </dynamsoft:DCVCameraView.TorchButton>
            </dynamsoft:DCVCameraView>
            <Label x:Name="label" Text = ''
                   AbsoluteLayout.LayoutBounds="0.5,0.5,300,25"
                   AbsoluteLayout.LayoutFlags="PositionProportional"/>
        </AbsoluteLayout>-->
        <Grid RowSpacing="0" ColumnSpacing="0" BackgroundColor="Transparent" Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="1*"/>
                <RowDefinition Height="250"/>
                <RowDefinition Height="2*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <zxing:CameraBarcodeReaderView x:Name="barcodeView"
                                           Grid.RowSpan="3" 
                                           Grid.ColumnSpan="3"
                                           IsTorchOn="{Binding IsTorch,Mode=TwoWay}"
                                           IsDetecting="{Binding IsScanning,Mode=TwoWay}"
                                           BarcodesDetected="ZXingScannerView_OnScanResult"
                                           IsEnabled="{Binding IsAnalyzing,Mode=TwoWay}"/>
            <BoxView Grid.Row="0" 
                     Grid.ColumnSpan="3" 
                     BackgroundColor="{StaticResource HoverBackgroundColor}"/>
            <BoxView Grid.Row="1" 
                     Grid.Column="0" 
                     BackgroundColor="{StaticResource HoverBackgroundColor}"/>
            <BoxView Grid.Row="1" 
                     Grid.Column="2" 
                     BackgroundColor="{StaticResource HoverBackgroundColor}"/>
            <BoxView Grid.Row="2" 
                     Grid.ColumnSpan="3" 
                     BackgroundColor="{StaticResource HoverBackgroundColor}"/>
            <Label x:Name="ResultLabel"
                   Grid.Row="0" 
                   Grid.Column="1" 
                   Margin="0,0,0,10" 
                   BackgroundColor="Transparent" 
                   TextColor="White" 
                   Text="" 
                   VerticalOptions="End" 
                   HorizontalOptions="Center"/>
            <BoxView x:Name="topLine" 
                     Grid.Row="1" 
                     Grid.Column="1" 
                     Margin="1,1,1,0" 
                     BackgroundColor="White" 
                     HeightRequest="1" 
                     VerticalOptions="Start" 
                     HorizontalOptions="FillAndExpand"/>
            <BoxView x:Name="bottomLine" 
                     Grid.Row="1" 
                     Grid.Column="1" 
                     Margin="1,0,1,1" 
                     BackgroundColor="White" 
                     HeightRequest="1"
                     VerticalOptions="End" 
                     HorizontalOptions="FillAndExpand"/>
            <BoxView Grid.Row="1" 
                     Grid.Column="1" 
                     Margin="1,1,0,1" 
                     BackgroundColor="White" 
                     WidthRequest="1" 
                     HorizontalOptions="Start" 
                     VerticalOptions="FillAndExpand"/>
            <BoxView Grid.Row="1" 
                     Grid.Column="1" 
                     Margin="0,1,1,1" 
                     BackgroundColor="White" 
                     WidthRequest="1" 
                     HorizontalOptions="End" 
                     VerticalOptions="FillAndExpand"/>
            <Image Grid.Row="1" 
                   Grid.Column="1" 
                   Source="left_top" 
                   WidthRequest="20"
                   HorizontalOptions="Start" 
                   VerticalOptions="Start"/>
            <Image Grid.Row="1" 
                   Grid.Column="1" 
                   Source="right_top" 
                   WidthRequest="20"
                   HorizontalOptions="End" 
                   VerticalOptions="Start"/>
            <Image Grid.Row="1" 
                   Grid.Column="1" 
                   Source="left_bottom" 
                   WidthRequest="20"
                   HorizontalOptions="Start" 
                   VerticalOptions="End"/>
            <Image Grid.Row="1" 
                   Grid.Column="1" 
                   Source="right_bottom" 
                   WidthRequest="20"
                   HorizontalOptions="End" 
                   VerticalOptions="End"/>
            <Image x:Name="line" 
                   Grid.Row="1" 
                   Grid.Column="1" 
                   Source="animate_line" 
                   VerticalOptions="Start"/>
        </Grid>
    </pages:CustomPage.Content>
</pages:CustomPage>